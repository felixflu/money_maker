# Environment Configuration Template
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=money_maker
DATABASE_URL=postgresql://postgres:postgres@db:5432/money_maker

# ===========================================
# Backend Configuration
# ===========================================
ENV=development
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost

# ===========================================
# WealthAPI Configuration
# ===========================================
# Obtain sandbox credentials from WealthAPI support:
# https://sandbox.wealthapi.eu — contact support@wealthapi.eu for access
WEALTHAPI_CLIENT_ID=your-wealthapi-client-id
WEALTHAPI_CLIENT_SECRET=your-wealthapi-client-secret
# Sandbox: https://sandbox.wealthapi.eu (default)
# Production: https://wealthapi.eu
WEALTHAPI_BASE_URL=https://sandbox.wealthapi.eu

# ===========================================
# Frontend Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
